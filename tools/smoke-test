#!/usr/bin/env bash
#
# smoke-test — Verify all feature routes respond correctly
# Checks /api/health and all routes from .speckit/features.json
#
# Usage:
#   ./tools/smoke-test [URL]
#
# Arguments:
#   URL    Base URL to test (default: reads .staging-url, or http://localhost:3000)
#
# Options:
#   --features <path>   Path to features.json (default: .speckit/features.json)
#   --timeout <secs>    Curl timeout per request (default: 10)
#   -h, --help          Show this help

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[smoke]${NC}  $*"; }
success() { echo -e "${GREEN}[smoke]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[smoke]${NC}  $*"; }
error()   { echo -e "${RED}[smoke]${NC}  $*" >&2; }
die()     { error "$@"; exit 1; }

FEATURES_PATH=".speckit/features.json"
CURL_TIMEOUT=10
BASE_URL=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --features) FEATURES_PATH="$2"; shift 2 ;;
        --timeout)  CURL_TIMEOUT="$2"; shift 2 ;;
        -h|--help)
            echo "Usage: $(basename "$0") [URL] [--features <path>] [--timeout <secs>]"
            echo "Verify all feature routes respond correctly."
            exit 0 ;;
        -*)  die "Unknown option: $1" ;;
        *)   BASE_URL="$1"; shift ;;
    esac
done

# Resolve base URL
if [ -z "$BASE_URL" ]; then
    if [ -f ".staging-url" ]; then
        BASE_URL="https://$(cat .staging-url)"
        info "Using staging URL from .staging-url"
    else
        BASE_URL="http://localhost:3000"
        info "Using default: $BASE_URL"
    fi
fi

# Remove trailing slash
BASE_URL="${BASE_URL%/}"

info "Testing ${BOLD}${BASE_URL}${NC}"
echo ""

TOTAL=0
PASSED=0
FAILED=0

# Helper: test a single route
test_route() {
    local route="$1"
    TOTAL=$((TOTAL + 1))

    local status
    status=$(curl -s -o /dev/null -w "%{http_code}" --max-time "$CURL_TIMEOUT" "${BASE_URL}${route}" 2>/dev/null || echo "000")

    if [[ "$status" -ge 500 ]] || [[ "$status" == "000" ]]; then
        error "FAIL  ${route} → ${status}"
        FAILED=$((FAILED + 1))
        return 1
    elif [[ "$status" -ge 400 ]]; then
        warn "WARN  ${route} → ${status} (client error, may be expected)"
        PASSED=$((PASSED + 1))
        return 0
    else
        success "OK    ${route} → ${status}"
        PASSED=$((PASSED + 1))
        return 0
    fi
}

# 1. Health check
info "--- Health Check ---"
test_route "/api/health" "Health endpoint" || true
echo ""

# 2. Feature routes from features.json
if [ -f "$FEATURES_PATH" ]; then
    info "--- Feature Routes (from $(basename "$FEATURES_PATH")) ---"

    # Get routes from features with status done or staging
    ROUTES=$(jq -r '.features[] | select(.status == "done" or .status == "staging" or .status == "implementing") | .routes[]?' "$FEATURES_PATH" 2>/dev/null || true)

    if [ -z "$ROUTES" ]; then
        warn "No routes found in features.json (or no features with status done/staging/implementing)"
    else
        while IFS= read -r route; do
            [ -n "$route" ] && test_route "$route" || true
        done <<< "$ROUTES"
    fi
else
    warn "No features.json found at $FEATURES_PATH"
    warn "Testing only /api/health"
fi

# Summary
echo ""
echo -e "${BOLD}──────────────────────────────${NC}"
info "Total:  $TOTAL routes tested"
info "Passed: $PASSED"
if [[ $FAILED -gt 0 ]]; then
    error "Failed: $FAILED"
    echo ""
    error "Smoke test ${BOLD}FAILED${NC}"
    exit 1
else
    echo ""
    success "Smoke test ${BOLD}PASSED${NC}"
    exit 0
fi
