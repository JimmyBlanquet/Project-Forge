#!/usr/bin/env bash
#
# validate-feature — Post-feature validation checklist
# Runs TypeScript, lint, tests, quality scans, and build sequentially.
# Stops on first failure.
#
# Usage:
#   ./tools/validate-feature [options]
#
# Options:
#   --skip-build          Skip the Next.js build step
#   --dir <path>          Project directory (default: current directory)
#   -h, --help            Show this help
#

set -euo pipefail

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
info()    { echo -e "${BLUE}[validate]${NC}  $*"; }
success() { echo -e "${GREEN}[validate]${NC}  $*"; }
error()   { echo -e "${RED}[validate]${NC}  $*" >&2; }
die()     { error "$@"; exit 1; }

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
SKIP_BUILD=false
PROJECT_DIR="."

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --skip-build)
      SKIP_BUILD=true
      shift
      ;;
    --dir)
      [[ -z "${2:-}" ]] && die "--dir requires a path argument"
      PROJECT_DIR="$2"
      shift 2
      ;;
    -h|--help)
      sed -n '2,/^$/{ s/^# //; s/^#//; p }' "$0"
      exit 0
      ;;
    *)
      die "Unknown option: $1"
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Validate project directory
# ---------------------------------------------------------------------------
[[ -d "$PROJECT_DIR" ]] || die "Directory not found: $PROJECT_DIR"
cd "$PROJECT_DIR"
[[ -f "package.json" ]] || die "No package.json found in $(pwd)"

echo -e "\n${BOLD}Feature Validation${NC}  —  $(pwd)\n"

# ---------------------------------------------------------------------------
# Step 1: TypeScript check
# ---------------------------------------------------------------------------
info "Running TypeScript check..."
npx tsc --noEmit
success "TypeScript check passed"

# ---------------------------------------------------------------------------
# Step 2: Lint
# ---------------------------------------------------------------------------
info "Running Next.js lint..."
npx next lint
success "Lint passed"

# ---------------------------------------------------------------------------
# Step 3: Unit tests
# ---------------------------------------------------------------------------
info "Running unit tests..."
npx vitest run
success "Unit tests passed"

# ---------------------------------------------------------------------------
# Step 4: Quality scan
# ---------------------------------------------------------------------------
info "Running quality scan (jscpd)..."
npm run quality:jscpd
success "jscpd passed"

info "Running quality scan (knip)..."
npm run quality:knip
success "knip passed"

# ---------------------------------------------------------------------------
# Step 5: Build (unless --skip-build)
# ---------------------------------------------------------------------------
if [[ "$SKIP_BUILD" == "false" ]]; then
  info "Running Next.js build..."
  npx next build
  success "Build passed"
else
  info "${YELLOW}Build skipped${NC} (--skip-build)"
fi

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
echo ""
success "${BOLD}Feature validation PASSED${NC}"
