#!/usr/bin/env bash
#
# promote-to-prod — Create PR to main and optionally enable auto-merge
#
# Usage:
#   ./tools/promote-to-prod [options]
#
# Options:
#   --auto-merge    Enable auto-merge (squash) when CI passes
#   --no-delete     Don't delete branch after merge
#   --label <name>  Add label to PR (default: auto-promoted)
#   -h, --help      Show this help

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[promote]${NC}  $*"; }
success() { echo -e "${GREEN}[promote]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[promote]${NC}  $*"; }
error()   { echo -e "${RED}[promote]${NC}  $*" >&2; }
die()     { error "$@"; exit 1; }

AUTO_MERGE=false
DELETE_BRANCH=true
LABEL="auto-promoted"

while [[ $# -gt 0 ]]; do
    case $1 in
        --auto-merge) AUTO_MERGE=true; shift ;;
        --no-delete)  DELETE_BRANCH=false; shift ;;
        --label)      LABEL="$2"; shift 2 ;;
        -h|--help)
            echo "Usage: $(basename "$0") [--auto-merge] [--no-delete] [--label <name>]"
            echo "Create PR to main and optionally enable auto-merge."
            exit 0 ;;
        *) die "Unknown option: $1" ;;
    esac
done

# Prerequisites
command -v gh &>/dev/null || die "GitHub CLI (gh) not found. Install: https://cli.github.com/"
gh auth status &>/dev/null 2>&1 || die "Not logged in to GitHub. Run: gh auth login"

BRANCH=$(git branch --show-current)
[ -n "$BRANCH" ] || die "Not on a branch (detached HEAD?)"
[ "$BRANCH" != "main" ] || die "Already on main. Nothing to promote."

# Check for existing PR
EXISTING_PR=$(gh pr list --head "$BRANCH" --json number -q '.[0].number' 2>/dev/null || true)
if [ -n "$EXISTING_PR" ]; then
    info "PR #${EXISTING_PR} already exists for ${BRANCH}"
    PR_URL=$(gh pr view "$EXISTING_PR" --json url -q '.url')
    success "PR: ${BOLD}${PR_URL}${NC}"
else
    # Ensure branch is pushed
    info "Pushing ${BOLD}${BRANCH}${NC}..."
    git push -u origin "$BRANCH" 2>/dev/null || die "Could not push branch"

    # Create PR
    info "Creating PR to main..."
    PR_URL=$(gh pr create \
        --base main \
        --head "$BRANCH" \
        --fill \
        --label "$LABEL" 2>/dev/null) || die "Could not create PR"
    success "PR created: ${BOLD}${PR_URL}${NC}"
fi

# Auto-merge
if $AUTO_MERGE; then
    info "Enabling auto-merge (squash)..."
    merge_flags="--auto --squash"
    if $DELETE_BRANCH; then
        merge_flags="$merge_flags --delete-branch"
    fi
    if gh pr merge "$BRANCH" $merge_flags 2>/dev/null; then
        success "Auto-merge enabled — PR will merge when CI passes."
    else
        warn "Could not enable auto-merge. Enable manually or check repo settings."
        info "  gh pr merge $BRANCH --auto --squash --delete-branch"
    fi
else
    info "Merge manually after CI passes, or re-run with --auto-merge"
fi
