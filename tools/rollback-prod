#!/usr/bin/env bash
#
# Rollback Vercel production deployment
#
# Usage:
#   ./tools/rollback-prod                      # Rollback to previous deploy
#   ./tools/rollback-prod --to <deploy-id>     # Rollback to specific deploy
#
# Requires: vercel CLI + VERCEL_TOKEN env var
# Optional: gh CLI for GitHub issue creation (scope: issues:write)

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[rollback]${NC}  $*"; }
success() { echo -e "${GREEN}[rollback]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[rollback]${NC}  $*"; }
error()   { echo -e "${RED}[rollback]${NC}  $*" >&2; }
die()     { error "$@"; exit 1; }

DEPLOY_ID=""
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROLLBACK_LOG="${SCRIPT_DIR}/../rollback.log"

usage() {
    echo "Usage: $(basename "$0") [options]"
    echo ""
    echo "Rollback Vercel production deployment"
    echo ""
    echo "Options:"
    echo "  --to <deploy-id>    Rollback to a specific deployment"
    echo "  -h, --help          Show this help"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --to)
                DEPLOY_ID="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                die "Unknown option: $1 (see --help)"
                ;;
        esac
    done
}

validate_prerequisites() {
    if ! command -v vercel &>/dev/null; then
        die "vercel CLI not found. Install: npm i -g vercel"
    fi

    if [[ -z "${VERCEL_TOKEN:-}" ]]; then
        die "VERCEL_TOKEN environment variable is required"
    fi
}

validate_deploy_id() {
    if [[ -z "$DEPLOY_ID" ]]; then
        return
    fi

    info "Validating deploy ID: ${BOLD}${DEPLOY_ID}${NC}"
    if ! vercel inspect "$DEPLOY_ID" --token "$VERCEL_TOKEN" &>/dev/null; then
        die "Invalid deploy ID: $DEPLOY_ID (vercel inspect failed)"
    fi
    success "Deploy ID validated"
}

do_rollback() {
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    if [[ -n "$DEPLOY_ID" ]]; then
        info "Rolling back to deploy: ${BOLD}${DEPLOY_ID}${NC}"
        if ! vercel rollback "$DEPLOY_ID" --token "$VERCEL_TOKEN"; then
            die "Rollback failed"
        fi
    else
        info "Rolling back to previous deployment..."
        if ! vercel rollback --token "$VERCEL_TOKEN"; then
            die "Rollback failed"
        fi
    fi

    success "Rollback completed at ${timestamp}"

    # Build audit entry
    local audit_entry
    audit_entry="## Production Rollback - ${timestamp}
- Deploy ID: ${DEPLOY_ID:-previous}
- Triggered by: $(whoami)
- Reason: manual rollback"

    # Try to create GitHub issue for traceability
    create_audit_trail "$timestamp" "$audit_entry"
}

create_audit_trail() {
    local timestamp="$1"
    local audit_entry="$2"

    if command -v gh &>/dev/null; then
        local issue_title="Production rollback - ${timestamp}"
        local issue_body
        issue_body="$(cat <<EOF
## Production Rollback

| Field | Value |
|-------|-------|
| **Timestamp** | ${timestamp} |
| **Deploy ID** | ${DEPLOY_ID:-previous (latest rollback)} |
| **Triggered by** | $(whoami) |
| **Host** | $(hostname) |

## Action Required

- [ ] Investigate root cause
- [ ] Verify production is stable after rollback
- [ ] Create fix and redeploy

---
Generated by \`tools/rollback-prod\`
EOF
)"

        if gh issue create \
            --title "$issue_title" \
            --body "$issue_body" \
            --label "incident" \
            2>/dev/null; then
            success "GitHub issue created for traceability"
        else
            warn "Could not create GitHub issue (check gh auth scope: issues:write)"
            write_local_log "$audit_entry"
        fi
    else
        warn "gh CLI not found — skipping GitHub issue"
        write_local_log "$audit_entry"
    fi
}

write_local_log() {
    local entry="$1"
    echo "" >> "$ROLLBACK_LOG"
    echo "$entry" >> "$ROLLBACK_LOG"
    echo "---" >> "$ROLLBACK_LOG"
    info "Audit info saved to ${BOLD}${ROLLBACK_LOG}${NC}"

    # Also print to stdout for visibility during incident
    echo ""
    echo "$entry"
}

main() {
    parse_args "$@"

    echo ""
    echo -e "${BOLD}${RED}  ╔══════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${RED}  ║     Production Rollback               ║${NC}"
    echo -e "${BOLD}${RED}  ╚══════════════════════════════════════╝${NC}"
    echo ""

    validate_prerequisites
    validate_deploy_id
    do_rollback
}

main "$@"
