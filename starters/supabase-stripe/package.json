{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "drizzle-kit migrate && next build",
    "vercel-build": "bash scripts/vercel-gatekeeper-check.sh && drizzle-kit migrate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stripe:setup": "tsx --env-file=.env stripeSetup.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/webhook/stripe",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:plan": "echo 'Use: claude \"Use the planner agent to create a test plan for [feature]\"'",
    "test:e2e:heal": "echo 'Use: claude \"Use the healer agent to fix failing tests\"'",
    "test:e2e:ci-heal": "bash scripts/ci-healer.sh --create-pr",
    "test:arch": "vitest run tests/architecture/",
    "verify:staging": "bash scripts/verify-deployment.sh staging",
    "verify:production": "bash scripts/verify-deployment.sh production",
    "quality:scan": "jscpd --config .jscpd.json && knip && next lint",
    "quality:jscpd": "jscpd --config .jscpd.json",
    "quality:knip": "knip",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "prepare": "husky",
    "test:mutation": "stryker run",
    "test:traceability": "bash scripts/verify-test-traceability.sh"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.24.2",
    "drizzle-orm": "^0.33.0",
    "lucide-react": "^0.428.0",
    "next": "14.2.35",
    "postgres": "^3.4.4",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.3.0",
    "stripe": "^16.9.0",
    "zod": "^3.23.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.8",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^3.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jscpd": "^4.0.5",
    "knip": "^5.44.0",
    "eslint-plugin-sonarjs": "^3.0.2",
    "wait-on": "^8.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.0.0",
    "@playwright/test": "^1.52.0",
    "@playwright/mcp": "latest",
    "@stryker-mutator/core": "^8.0.0",
    "@stryker-mutator/vitest-runner": "^8.0.0",
    "@stryker-mutator/typescript-checker": "^8.0.0"
  }
}
