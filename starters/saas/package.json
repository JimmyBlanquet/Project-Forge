{
  "name": "saas-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "drizzle-kit migrate && next build",
    "vercel-build": "bash scripts/vercel-gatekeeper-check.sh && drizzle-kit migrate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "npx tsx lib/db/setup.ts",
    "db:seed": "npx tsx lib/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:arch": "vitest run tests/architecture/",
    "quality:scan": "jscpd --config .jscpd.json && knip && next lint",
    "quality:jscpd": "jscpd --config .jscpd.json",
    "quality:knip": "knip",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "prepare": "husky",
    "test:traceability": "bash scripts/verify-test-traceability.sh"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tailwindcss/postcss": "4.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "lucide-react": "^0.511.0",
    "next": "15.3.3",
    "postcss": "^8.5.3",
    "postgres": "^3.4.5",
    "radix-ui": "^1.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1",
    "stripe": "^18.1.0",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "4.1.7",
    "tw-animate-css": "^1.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "typescript": "^5.8.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.3.3",
    "eslint-plugin-sonarjs": "^3.0.2",
    "vitest": "^3.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@playwright/test": "^1.52.0",
    "jscpd": "^4.0.5",
    "knip": "^5.44.0",
    "wait-on": "^8.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.0.0"
  }
}
