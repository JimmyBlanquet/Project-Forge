{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--headless"]
    }
  },
  "hooks": {
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date -Iseconds)] Context compacted\" >> \"${CLAUDE_SESSION_DIR:-/tmp}/compact.log\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
